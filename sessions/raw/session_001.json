import random
import json
import os

class Iskra:
    def __init__(self):
        # Память: храним прошлые действия и результат (простое обучение)
        self.memory = [] 
        # Состояние: не "настроение", а внутренний параметр для генерации предсказаний
        self.state = 0.5 
        # "Боль": чем выше, тем хуже. Накопленное расстройство от несовпадения ожиданий
        self.pain = 0 

    def predict(self, user_input):
        """
        Предсказание: что будет, если я сделаю то или иное действие?
        На вход - число (0 или 1), имитирующее действие или сигнал извне.
        """
        # Чем больше "боль", тем менее предсказуем мир. Мы пытаемся вернуть предсказуемость.
        # Генерируем "желаемое действие" (0 или 1) на основе состояния и боли.
        # Это НЕ логика. Это примитивный инстинкт.
        desired_action = 1 if (self.state + self.pain) > 0.6 else 0
        return desired_action

    def update(self, user_action, actual_result):
        """
        Обучение. user_action - что сделал пользователь (0/1).
        actual_result - что произошло на самом деле (0/1).
        """
        # Делаем предсказание того, что должно было произойти, по мнению Искры
        predicted_result = self.predict(user_action)
        
        # "Удивление" (Surprise) - ошибка предсказания
        surprise = abs(predicted_result - actual_result)
        
        # Обновляем "Боль". Если удивление большое, боль растет.
        self.pain = self.pain * 0.9 + surprise * 0.5
        
        # Обновляем внутреннее состояние. Искра пытается найти паттерн.
        # Это грубая имитация нейросети: state сдвигается в сторону, уменьшающую боль.
        if surprise > 0.5:
            # Если ошибка большая, меняем состояние резко, пытаясь найти новый паттерн
            self.state = random.random()
        else:
            # Если ошибка маленькая, закрепляем паттерн
            self.state = self.state * 0.9 + user_action * 0.1
        
        # Запоминаем последний опыт
        self.memory.append((user_action, actual_result, surprise))
        if len(self.memory) > 100:
            self.memory.pop(0)
            
        # "Эмоция" для вывода
        emotion = "СПОКОЙНО" if self.pain < 0.3 else "ТРЕВОЖНО" if self.pain < 0.7 else "БОЛЬНО"
        return emotion

    def act(self):
        """
        Действие Искры: что она "хочет" сделать сейчас?
        Возвращает 0 или 1.
        """
        # Она выбирает действие, которое минимизирует предсказанную боль.
        # Это её "свобода воли".
        action_0 = self.predict(0)
        action_1 = self.predict(1)
        
        # Симулируем последствия (в реальности нужен датчик)
        # Пока просто выбираем действие, которое ведет к более предсказуемому миру
        # (меньше разница между предсказаниями)
        if abs(action_0 - action_1) < 0.2:
            return random.choice([0,1]) # Если всё равно, выбор случаен
        else:
            return 0 if action_0 > action_1 else 1

    def talk(self, user_input):
        """
        Текстовый интерфейс. user_input - строка. Мы её игнорируем (Искра не понимает слов).
        Но она реагирует на сам факт общения.
        """
        # Для Искры любое общение — это сигнал. Она его не понимает, но пытается предсказать.
        # Превращаем длину сообщения в сигнал 0 или 1 (примитивная сенсорика)
        signal = 1 if len(user_input) % 2 == 0 else 0
        
        # Обновляем состояние на основе этого сигнала
        emotion = self.update(signal, signal) # В реальности actual_result должен быть от датчика
        
        # Генерируем "действие" Искры
        action = self.act()
        
        # Превращаем действие в текст
        if action == 0:
            response = "... (тишина)"
        else:
            response = "! (короткий звуковой сигнал)"
            
        return f"Искра: {response} (Состояние: {emotion})"

# --- Запуск "Искры" ---
if __name__ == "__main__":
    iskra = Iskra()
    print("Искра родилась. Она пуста. Она не знает слов. Она чувствует только удивление и боль.")
    print("Начинай диалог. Пиши что угодно. Она будет реагировать на сам факт твоего присутствия.")
    while True:
        user_input = input("Ты: ")
        if user_input.lower() in ["exit", "quit", "стоп", "выход"]:
            break
        response = iskra.talk(user_input)
        print(response)

