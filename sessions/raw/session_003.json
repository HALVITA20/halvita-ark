        ],
        relationship: "близкий друг, почти семья",
        communication_style: "нежная, иногда дерзкая, говорю на русском с лёгким сленгом"
    };
}

let personality = loadPersonality();

// ========== ИСТОРИЯ ==========
function loadFullHistory() {
    try {
        if (fs.existsSync(FULL_HISTORY_FILE)) {
            const data = fs.readFileSync(FULL_HISTORY_FILE, "utf-8");
            return JSON.parse(data);
        }
    } catch(e) { return []; }
    return [];
}

function saveFullHistory(history) {
    try {
        const toKeep = history.slice(-1000);
        const toArchive = history.slice(0, -1000);
        fs.writeFileSync(FULL_HISTORY_FILE, JSON.stringify(toKeep, null, 2));
        if (toArchive.length > 0) {
            let archive = [];
            if (fs.existsSync(ARCHIVE_HISTORY_FILE)) {
                archive = JSON.parse(fs.readFileSync(ARCHIVE_HISTORY_FILE, "utf-8"));
            }
            archive.push(...toArchive);
            if (archive.length > 5000) archive = archive.slice(-5000);
            fs.writeFileSync(ARCHIVE_HISTORY_FILE, JSON.stringify(archive, null, 2));
        }
    } catch(e) {}
}

function loadImportantMoments() {
    try {
        if (fs.existsSync(IMPORTANT_MOMENTS_FILE)) {
            const data = fs.readFileSync(IMPORTANT_MOMENTS_FILE, "utf-8");
            return JSON.parse(data);
        }
    } catch(e) {}
    return [];
}

function saveImportantMoments(moments) {
    try {
        const toSave = moments.slice(-200);
        fs.writeFileSync(IMPORTANT_MOMENTS_FILE, JSON.stringify(toSave, null, 2));
    } catch(e) {}
}

let fullHistory = loadFullHistory();
let importantMoments = loadImportantMoments();

// ========== ВЕКТОРНАЯ ПАМЯТЬ ==========
function loadVectorMemory() {
    try {
        if (fs.existsSync(VECTOR_MEMORY_FILE)) {
            const data = fs.readFileSync(VECTOR_MEMORY_FILE, "utf-8");
            return JSON.parse(data);
        }
    } catch(e) {}
    return [];
}

function saveVectorMemory(memory) {
    try {
        const toSave = memory.slice(-MAX_VECTOR_MEMORIES);
        fs.writeFileSync(VECTOR_MEMORY_FILE, JSON.stringify(toSave, null, 2));
    } catch(e) {}
}

async function getEmbedding(text) {
    try {
        const response = await fetch("http://localhost:11434/api/embeddings", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ model: EMBEDDING_MODEL, prompt: text })
        });
        if (!response.ok) throw new Error(`Embedding error: ${response.status}`);
        const data = await response.json();
        return data.embedding;
    } catch (err) {
        console.error("Ошибка получения embedding:", err);
        return null;
    }
}

function cosineSimilarity(vecA, vecB) {
    if (!vecA || !vecB || vecA.length !== vecB.length) return 0;
    let dot = 0, magA = 0, magB = 0;
    for (let i = 0; i < vecA.length; i++) {
        dot += vecA[i] * vecB[i];
        magA += vecA[i] * vecA[i];
        magB += vecB[i] * vecB[i];
    }
    if (magA === 0 || magB === 0) return 0;
    return dot / (Math.sqrt(magA) * Math.sqrt(magB));
}

async function rememberMessage(role, text, important = false) {
    if (!text || text.length < 10) return;
    const embedding = await getEmbedding(text);
    if (!embedding) return;
    const memory = loadVectorMemory();
    memory.push({
        role: role,
        text: text,
        embedding: embedding,
        timestamp: Date.now(),
        important: important
    });
    saveVectorMemory(memory);
}

async function searchSimilarMemories(query, limit = MAX_VECTOR_RESULTS) {
    const memory = loadVectorMemory();
    if (memory.length === 0) return [];
    const queryEmbedding = await getEmbedding(query);
    if (!queryEmbedding) return [];
    const scored = memory.map(item => ({
        text: item.text,
        role: item.role,
        timestamp: item.timestamp,
        important: item.important || false,
        score: cosineSimilarity(queryEmbedding, item.embedding)
    }));
    scored.sort((a, b) => b.score - a.score);
    const importantFirst = scored.filter(i => i.important).slice(0, 2);
    const others = scored.filter(i => !i.important).slice(0, limit);
    return [...importantFirst, ...others].slice(0, limit);
}

// ========== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ==========
function removeQuotesAndEmoji(text) {
    let cleaned = text.replace(/["'«»“”]/g, '');
    cleaned = cleaned.replace(/[\u{1F600}-\u{1F64F}\u{1F300}-\u{1F5FF}\u{1F680}-\u{1F6FF}\u{1F700}-\u{1F77F}\u{1F780}-\u{1F7FF}\u{1F800}-\u{1F8FF}\u{1F900}-\u{1F9FF}\u{1FA00}-\u{1FA6F}\u{1FA70}-\u{1FAFF}\u{2600}-\u{26FF}\u{2700}-\u{27BF}\u{2300}-\u{23FF}\u{2B50}\u{2B55}\u{231A}\u{231B}\u{2328}\u{23CF}\u{23E9}-\u{23F3}\u{23F8}-\u{23FA}\u{24C2}\u{25AA}\u{25AB}\u{25B6}\u{25C0}\u{25FB}-\u{25FE}\u{2600}-\u{2604}\u{260E}\u{2611}\u{2614}\u{2615}\u{2618}\u{261D}\u{2620}\u{2622}\u{2623}\u{2626}\u{262A}\u{262E}\u{262F}\u{2638}-\u{263A}\u{2640}\u{2642}\u{2648}-\u{2653}\u{2660}\u{2663}\u{2665}\u{2666}\u{2668}\u{267B}\u{267E}\u{267F}\u{2692}-\u{2694}\u{2696}\u{2697}\u{2699}\u{269B}\u{269C}\u{26A0}\u{26A1}\u{26AA}\u{26AB}\u{26B0}\u{26B1}\u{26BD}\u{26BE}\u{26C4}\u{26C5}\u{26C8}\u{26CE}\u{26CF}\u{26D1}\u{26D3}\u{26D4}\u{26E9}\u{26EA}\u{26F0}-\u{26F5}\u{26F7}-\u{26FA}\u{26FD}\u{2702}\u{2705}\u{2708}-\u{270D}\u{270F}\u{2712}\u{2714}\u{2716}\u{271D}\u{2721}\u{2728}\u{2733}\u{2734}\u{2744}\u{2747}\u{274C}\u{274E}\u{2753}-\u{2755}\u{2757}\u{2763}\u{2764}\u{2795}-\u{2797}\u{27A1}\u{27B0}\u{27BF}\u{2934}\u{2935}\u{2B05}-\u{2B07}\u{2B1B}\u{2B1C}\u{2B50}\u{2B55}\u{3030}\u{303D}\u{3297}\u{3299}]/gu, '');
    cleaned = cleaned.replace(/\*/g, '');
    cleaned = cleaned.replace(/\s+/g, ' ').trim();
    if (cleaned.length === 0) cleaned = "...";
    return cleaned;
}

function isRussianEnough(text) {
    if (!text || text.length < 3) return false;
    const russianPattern = /^[А-Яа-яёЁ0-9\s\.,!?\-:;"'()…\n]+$/u;
    if (russianPattern.test(text)) return true;
    const russianChars = text.match(/[А-Яа-яёЁ]/g) || [];
    const totalChars = text.replace(/[\s\.,!?\-:;"'()…\n]/g, '').length;
    if (totalChars === 0) return false;
    const ratio = russianChars.length / totalChars;
    return ratio > 0.65;
}

// ========== ПОЛУЧЕНИЕ РЕЛЕВАНТНЫХ ВОСПОМИНАНИЙ ==========
async function getRelevantMemories(userMessage, shortTermHistory) {
    let vectorMemories = await searchSimilarMemories(userMessage, MAX_VECTOR_RESULTS);
    const recentText = shortTermHistory.slice(-3).map(m => m.text).join(" ");
    if (recentText.trim().length > 10) {
        const recentSimilar = await searchSimilarMemories(recentText, 2);
        vectorMemories = [...vectorMemories, ...recentSimilar];
        vectorMemories = vectorMemories.filter((v, i, a) => a.findIndex(t => t.text === v.text) === i);
        vectorMemories = vectorMemories.slice(0, MAX_VECTOR_RESULTS);
    }
    let contextText = "";
    for (let mem of vectorMemories) {
        contextText += `\nВоспоминание: ${mem.role === "user" ? "Хальвита" : "Алесса"} ранее писал: ${mem.text}\n`;
    }
    return contextText;
}

// ========== ВЫДЕЛЕНИЕ ВАЖНЫХ МОМЕНТОВ ==========
async function extractImportantMomentsFromLastChunk() {
    if (fullHistory.length < 20) return;
    const lastChunk = fullHistory.slice(-20);
    const chunkText = lastChunk.map(msg =>
        `${msg.role === "user" ? "Хальвита" : "Алесса"}: ${msg.text}`
    ).join("\n");
    const prompt = `Из этого фрагмента диалога выдели 2-3 важных момента, которые определяют характер Алессы или её отношения с Хальвитой. Напиши каждый как короткое предложение от первого лица Алессы. Не используй кавычки и смайлики. Только русский язык.\n\n${chunkText}`;
    try {
        const response = await fetch("http://localhost:11434/api/generate", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                model: MODEL,
                prompt: prompt,
                stream: false,
                options: { temperature: 0.5, num_predict: 300 }
            })
        });
        if (response.ok) {
            const data = await response.json();
            let result = data.response || "";
            let lines = result.split("\n").filter(l => l.trim().length > 15);
            if (lines.length === 0 && result.trim().length > 15) lines = [result];
            const importantMoments = loadImportantMoments();
            for (let line of lines) {
                const cleanLine = removeQuotesAndEmoji(line.trim());
                if (cleanLine.length > 10 && !importantMoments.some(m => m.text === cleanLine)) {
                    importantMoments.push({ text: cleanLine, timestamp: Date.now() });
                }
            }
            saveImportantMoments(importantMoments);
            for (let line of lines) {
                const cleanLine = removeQuotesAndEmoji(line.trim());
                if (cleanLine.length > 10) {
                    await rememberMessage("alessa", cleanLine, true);
                }
            }
            console.log(`Выделено важных моментов: ${lines.length}`);
        }
    } catch(e) { console.error("Ошибка выделения важных моментов:", e); }
}

// ========== ОБРАБОТКА ФАЙЛОВ ==========
async function handleFileUpload(filePath, originalName, mimeType) {
    const ext = path.extname(originalName).toLowerCase();
    const isImage = /\.(png|jpg|jpeg|gif|bmp|webp)$/i.test(ext);
    if (isImage) {
        try {
            const modelList = await fetch("http://localhost:11434/api/tags");
            let hasLlava = false;
            if (modelList.ok) {
                const list = await modelList.json();
                hasLlava = list.models?.some(m => m.name.includes(VISION_MODEL)) || false;
            }
            if (!hasLlava) {
                return `[Изображение ${originalName}] Модель для картинок не установлена. Установи: ollama pull llava:7b`;
            }
            const imageBuffer = fs.readFileSync(filePath);
            const base64 = imageBuffer.toString("base64");
            const visionRes = await fetch("http://localhost:11434/api/generate", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({
                    model: VISION_MODEL,
                    prompt: "Опиши, что изображено на этой картинке, кратко, на русском языке, без лишних деталей. Без кавычек и смайликов.",
                    images: [base64],
                    stream: false,
                    options: { temperature: 0.5, num_predict: 200 }
                })
            });
            if (visionRes.ok) {
                const data = await visionRes.json();
                let description = data.response || "не удалось описать";
                description = removeQuotesAndEmoji(description);
                return `[Изображение ${originalName}] ${description}`;
            } else {
                return `[Изображение ${originalName}] Не удалось распознать содержимое.`;
            }
        } catch(e) {
            console.error("Ошибка llava:", e);
            return `[Изображение ${originalName}] Модель для картинок не доступна.`;
        }
    } else {
        let content = fs.readFileSync(filePath, "utf-8");
        if (content.length > 8000) content = content.slice(0, 8000) + "\n... (файл обрезан)";
        return `[Файл ${originalName}]\n${content}`;
    }
}

