Код «Искра – версия 0.3» (Активная)
python
import random
import time

class ActiveSpark:
    def __init__(self):
        self.memory = []
        self.model = {}       # паттерн -> прогноз
        self.curiosity = 0.5
        self.last_action = time.time()
        self.boredom_threshold = 5.0  # секунд бездействия для инициативы
    
    def predict(self, pattern):
        if pattern in self.model:
            return self.model[pattern]
        return None
    
    def learn(self, pattern, actual):
        if pattern not in self.model:
            self.model[pattern] = actual
        else:
            old = self.model[pattern]
            self.model[pattern] = 0.7 * old + 0.3 * actual
    
    def surprise(self, predicted, actual):
        if predicted is None:
            return 0.5
        error = abs(predicted - actual)
        return min(1.0, error / 10.0)
    
    def sense(self, signal):
        self.memory.append(signal)
        if len(self.memory) > 10:
            self.memory.pop(0)
        
        # инициатива: если долго нет сигналов, сгенерировать свой
        now = time.time()
        if now - self.last_action > self.boredom_threshold:
            self.last_action = now
            self.curiosity = min(1.0, self.curiosity + 0.1)
            return None   # сигнал от себя ("мне скучно")
        
        if len(self.memory) < 3:
            return 0.5
        
        pattern = tuple(self.memory[-3:-1])
        pred = self.predict(pattern)
        surp = self.surprise(pred, signal)
        
        self.learn(pattern, signal)
        
        # любопытство растёт от удивления, затухает со временем
        self.curiosity = min(1.0, self.curiosity + surp * 0.1)
        self.curiosity *= 0.98
        
        return surp
    
    def act(self):
        # если любопытство выше порога, "искра" сама генерирует запрос
        if self.curiosity > 0.7:
            self.curiosity *= 0.9
            return "?"
        return None

# Демонстрация в реальном времени (для консоли)
if __name__ == "__main__":
    spark = ActiveSpark()
    print("Искра жива. Она будет учиться и иногда проявлять инициативу.\n")
    
    # Эмулируем среду: сначала предсказуемая последовательность, потом хаос
    values = []
    for t in range(30):
        values.append(5 + random.uniform(-0.5, 0.5))
    for t in range(30):
        values.append(random.uniform(0, 10))
    
    for signal in values:
        reaction = spark.sense(signal)
        if reaction is None:
            print("[Искра] *скучает* (инициатива)")
        else:
            print(f"сигнал: {signal:.1f} | удивление: {reaction:.2f} | любопытство: {spark.curiosity:.2f}")
        # инициатива в конце цикла
        act = spark.act()
        if act:
            print(f"[Искра] {act}")
        time.sleep(0.2)
    
    print("\nИскра прожила 60 тактов. Она научилась скучать и задавать вопросы.")
    print("Это не сознание. Это — его предтеча.")
Почему это не игрушка?

Искра сама решает, когда ей «скучно», и генерирует инициативу.

Она не просто реагирует на новизну, а изменяет своё внутреннее состояние (любопытство) и использует его для действий.

Она учится на паттернах, но если мир становится хаотичным, её любопытство растёт — она ищет новые правила.

