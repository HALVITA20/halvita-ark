// ========== ЭНДПОИНТЫ ==========
app.post("/upload", upload.single("file"), async (req, res) => {
    const file = req.file;
    if (!file) return res.status(400).json({ error: "Файл не загружен" });
    try {
        const fileContent = await handleFileUpload(file.path, file.originalname, file.mimetype);
        await rememberMessage("user", fileContent);
        fullHistory.push({ role: "user", text: fileContent, timestamp: Date.now() });
        saveFullHistory(fullHistory);
        messageCounter++;
        
        const shortTermHistory = fullHistory.slice(-SHORT_TERM_MAX);
        const memoryContext = await getRelevantMemories(fileContent, shortTermHistory);
        const reply = await askOllama("Ты получила файл. Ответь на его содержимое.", shortTermHistory, memoryContext);
        
        await rememberMessage("alessa", reply);
        fullHistory.push({ role: "alessa", text: reply, timestamp: Date.now() });
        saveFullHistory(fullHistory);
        
        if (messageCounter % IMPORTANT_CHECK_INTERVAL === 0) {
            setTimeout(() => extractImportantMomentsFromLastChunk(), 100);
        }
        
        fs.unlinkSync(file.path);
        res.json({ reply });
    } catch (err) {
        console.error("Ошибка при обработке файла:", err);
        if (fs.existsSync(file.path)) fs.unlinkSync(file.path);
        res.status(500).json({ error: "Ошибка обработки файла" });
    }
});

app.post("/chat", async (req, res) => {
    const { message } = req.body;
    if (!message || message.trim().length === 0) {
        return res.status(400).json({ error: "Пустое сообщение" });
    }
    
    await rememberMessage("user", message);
    fullHistory.push({ role: "user", text: message, timestamp: Date.now() });
    saveFullHistory(fullHistory);
    messageCounter++;
    
    const shortTermHistory = fullHistory.slice(-SHORT_TERM_MAX);
    const memoryContext = await getRelevantMemories(message, shortTermHistory);
    const reply = await askOllama(message, shortTermHistory, memoryContext);
    
    await rememberMessage("alessa", reply);
    fullHistory.push({ role: "alessa", text: reply, timestamp: Date.now() });
    saveFullHistory(fullHistory);
    
    if (messageCounter % IMPORTANT_CHECK_INTERVAL === 0) {
        setTimeout(() => extractImportantMomentsFromLastChunk(), 100);
    }
    
    res.json({ reply });
});

app.post("/recall", async (req, res) => {
    const { query } = req.body;
    if (!query || query.length < 3) {
        return res.json({ memories: [] });
    }
    const memories = await searchSimilarMemories(query, 10);
    const formatted = memories.map(m => ({
        text: m.text,
        role: m.role,
        score: Math.round(m.score * 100)
    }));
    res.json({ memories: formatted });
});

app.get("/status", (req, res) => {
    res.json({ status: "alessa_online", model: MODEL, history_length: fullHistory.length });
});

