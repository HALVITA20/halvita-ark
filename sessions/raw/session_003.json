    else:
        print(f"t={t:2d} | сигнал={signal:4.1f} | разогрев... | удивление={surprise:.2f} | любопытство={curiosity:.2f}")

print("\nИскра заметила: после плавных сигналов резко наступил хаос. Её любопытство выросло, потому что предсказания стали ошибаться.")
