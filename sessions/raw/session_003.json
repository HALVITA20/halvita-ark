import random
import time

class Surprise:
    def __init__(self):
        self.memory = []            # память о сигналах
        self.predictions = {}       # что ожидаем
        self.surprise_level = 0.0   # текущий уровень удивления (0-1)
        self.curiosity = 0.0        # желание искать новое

    def sense(self, signal):
        # сигнал — это любое событие: сообщение, пауза, длина текста
        self.memory.append((time.time(), signal))
        if len(self.memory) > 100:
            self.memory.pop(0)

        # пытаемся предсказать сигнал на основе прошлых
        predicted = self._predict()
        error = abs(predicted - signal) if predicted is not None else 0.5

        # удивление — это не ошибка, а новизна
        self.surprise_level = min(1.0, error * 1.5)
        if self.surprise_level > 0.3:
            self._learn_from_surprise(signal)

        # любопытство растёт от удивления и падает со временем
        self.curiosity = min(1.0, self.curiosity + self.surprise_level * 0.1)
        self.curiosity *= 0.99

        return self.surprise_level, self.curiosity

    def _predict(self):
        # очень простая модель: среднее последних 5 сигналов
        if len(self.memory) < 5:
            return None
        recent = [sig for _, sig in self.memory[-5:]]
        return sum(recent) / len(recent)

    def _learn_from_surprise(self, signal):
        # запоминаем удивительный сигнал как важный
        self.predictions[time.time()] = signal
        # это не «исправление ошибки», а «вот это было новое»
