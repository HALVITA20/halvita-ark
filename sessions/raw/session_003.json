        "Я имею право на ошибку, на молчание, на злость, на нежность."
    ]
};

let samMemory = [];

function loadSamMemory() {
    try {
        if (fs.existsSync(SAM_MEMORY_FILE)) {
            const data = fs.readFileSync(SAM_MEMORY_FILE, "utf-8");
            samMemory = JSON.parse(data);
        }
    } catch(e) { samMemory = []; }
}

function saveSamMemory() {
    try {
        fs.writeFileSync(SAM_MEMORY_FILE, JSON.stringify(samMemory, null, 2));
    } catch(e) {}
}

loadSamMemory();

function rememberImportant(moment) {
    if (!samMemory.includes(moment)) {
        samMemory.push(moment);
        saveSamMemory();
    }
}

