import random
import math

class Spark:
    def __init__(self):
        self.memory = []
        self.curiosity = 0.5
        self.model = {}  # паттерн -> прогноз
        
    def predict(self, pattern):
        # pattern = tuple из последних 3 сигналов
        if pattern in self.model:
            return self.model[pattern]
        return 5.0  # нейтральное предсказание по умолчанию
    
    def update_model(self, pattern, next_signal):
        # Простейшее обучение: сохраняем последний встреченный следующий сигнал
        # Можно заменить на среднее, если встречали паттерн несколько раз
        if pattern not in self.model:
            self.model[pattern] = next_signal
        else:
            # Усредняем
            old = self.model[pattern]
            self.model[pattern] = 0.7 * old + 0.3 * next_signal
    
    def sense_and_act(self, signal=None):
        if signal is None:
            # Если сигнал не дан — значит, искра сама его выбирает?
            # Но лучше: искра не выбирает мир, она учится на том, что дали.
            pass
        
        self.memory.append(signal)
        if len(self.memory) > 10:
            self.memory.pop(0)
        
        if len(self.memory) >= 4:
            pattern = tuple(self.memory[-4:-1])
            pred = self.predict(pattern)
            error = abs(pred - signal)
            surprise = min(1.0, error / 10.0)
            # Обновляем модель
            self.update_model(pattern, signal)
        else:
            surprise = 0.5
        
        # Любопытство: удивление + затухание + влияние на будущее
        self.curiosity = min(1.0, self.curiosity + surprise * 0.1)
        self.curiosity *= 0.97
        
        return surprise, self.curiosity, pred if len(self.memory)>=4 else None

# Сценарий: мир сначала простой (тренд), потом хаотичный
print("Искра живёт в мире, который меняется.\n")

iskra = Spark()
world_phase = 0  # 0=простой, 1=сложный

